set -e\
FAILED=()\
\
try() {\
    echo -e "\n>>> $*"\
    "$@" || { echo "[FAILED] $*"; FAILED+=("$*"); }\
}\
\
# Ōā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤Ć\
# pacman / AUR (yay)\
# Ōā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤Ć\
echo "=== pacman / AUR ==="\
\
PACMAN_PKGS=(\
    # c / c++ / objective-c\
    clang          # provides clangd\
\
    # Ada\
    ada-language-server  # AUR\
\
    # Lua\
    lua-language-server  # AUR\
\
    # Rust\
    rust-analyzer        # extra\
\
    # Python\
    python-lsp-server    # extra (pylsp)\
\
    # Nix\
    nil                  # AUR\
\
    # Vala\
    vala-language-server # AUR\
\
    # Gleam\
    gleam                # AUR\
\
    # Dart\
    dart                 # AUR (community)\
\
    # Kotlin\
    kotlin-language-server # AUR\
\
    # TeX / LaTeX\
    texlab               # AUR\
\
    # Marksman (Markdown)\
    marksman             # AUR\
\
    # QML (needs qt6-declarative which ships qmlls)\
    qt6-declarative\
\
    # ZLS (Zig)\
    zls                  # AUR\
\
    # XML (LemMinX)\
    lemminx              # AUR\
\
    # YAML\
    yaml-language-server # AUR\
\
    # Dockerfile\
    dockerfile-language-server # AUR\
)\
\
try yay -S --needed --noconfirm "${PACMAN_PKGS[@]}"\
\
# Ōā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤Ć\
# npm (global)\
# Ōā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤Ć\
echo -e "\n=== npm (global) ==="\
\
NPM_PKGS=(\
    bash-language-server             # Bash\
    vscode-langservers-extracted     # CSS, HTML, JSON (provides vscode-css-languageserver etc.)\
    typescript-language-server       # JS / TS / JSX / TSX\
    typescript                       # peer dep of typescript-language-server\
    "@vue/language-server"           # Vue\
    elm-language-server              # Elm\
    fish-lsp                         # fish\
    perlnavigator                    # Perl\
    purescript-language-server       # PureScript\
)\
\
for pkg in "${NPM_PKGS[@]}"; do\
    try npm install -g "$pkg"\
done\
\
# Ōā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤Ć\
# pip\
# Ōā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤Ć\
echo -e "\n=== pip ==="\
\
PIP_PKGS=(\
    "python-lsp-server[all]"   # pylsp ŌĆā┤ also catches the base pacman install\
    fortls                     # Fortran\
    esbonio                    # reStructuredText\
    rpm-spec-language-server   # RPM Spec (provides rpm_lsp_server)\
    blueprint-compiler         # GTK Blueprint (also available as AUR: blueprint-compiler)\
)\
\
for pkg in "${PIP_PKGS[@]}"; do\
    try pip install --user "$pkg"\
done\
\
# Ōā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤Ć\
# cargo\
# Ōā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤Ć\
echo -e "\n=== cargo ==="\
# Requires Rust toolchain. Install via: rustup toolchain install stable\
\
CARGO_PKGS=(\
    glsl_analyzer   # GLSL  (https://github.com/nolanderc/glsl_analyzer)\
    openscad-lsp    # OpenSCAD\
    tinymist        # Typst\
    vhdl_ls         # VHDL  (rust_hdl crate)\
)\
\
for pkg in "${CARGO_PKGS[@]}"; do\
    try cargo install "$pkg"\
done\
\
# Ōā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤Ć\
# Go\
# Ōā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤Ć\
echo -e "\n=== go install ==="\
# Requires Go toolchain.\
\
try go install golang.org/x/tools/gopls@latest   # Go LSP\
\
# Ōā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤Ć\
# .NET tools  (dotnet tool install -g)\
# Ōā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤Ć\
echo -e "\n=== .NET tools ==="\
# Requires dotnet SDK: yay -S dotnet-sdk\
\
try dotnet tool install -g csharp-ls          # C# (lighter alt; OmniSharp below)\
# OmniSharp standalone binary approach:\
OMNISHARP_DIR="$HOME/.local/share/omnisharp"\
if [[ ! -f "$OMNISHARP_DIR/OmniSharp" ]]; then\
    echo ">>> Downloading OmniSharp..."\
    mkdir -p "$OMNISHARP_DIR"\
    OMNI_URL=$(curl -s https://api.github.com/repos/OmniSharp/omnisharp-roslyn/releases/latest \\
        | grep "browser_download_url.*linux-x64.tar.gz" | cut -d '"' -f4 | head -1)\
    try curl -L "$OMNI_URL" | tar -xz -C "$OMNISHARP_DIR"\
    try ln -sf "$OMNISHARP_DIR/OmniSharp" "$HOME/.local/bin/OmniSharp"\
fi\
\
try dotnet tool install -g fsautocomplete      # F#\
\
# Ōā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤Ć\
# Ruby gem\
# Ōā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤Ć\
echo -e "\n=== gem ==="\
# Requires Ruby: sudo pacman -S ruby\
\
try gem install solargraph   # Ruby LSP\
\
# Ōā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤Ć\
# Haskell (ghcup / cabal)\
# Ōā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤Ć\
echo -e "\n=== Haskell (ghcup) ==="\
# Requires ghcup: https://www.haskell.org/ghcup/\
# curl --proto '=https' --tlsv1.2 -sSf https://get-ghcup.haskell.org | sh\
\
if command -v ghcup &>/dev/null; then\
    try ghcup install hls   # haskell-language-server-wrapper\
else\
    echo "[SKIP] ghcup not found. Install ghcup first, then run: ghcup install hls"\
    FAILED+=("haskell-language-server (ghcup not found)")\
fi\
\
# Ōā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤Ć\
# Java ŌĆā┤ Eclipse JDT LS (jdtls)\
# Ōā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤Ć\
echo -e "\n=== jdtls (Java) ==="\
# AUR package is the cleanest option on Arch:\
try yay -S --needed --noconfirm jdtls\
\
# Ōā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤Ć\
# Scala ŌĆā┤ Metals via coursier\
# Ōā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤Ć\
echo -e "\n=== Metals (Scala) via coursier ==="\
# Requires coursier: yay -S coursier  or  curl install\
if command -v cs &>/dev/null || command -v coursier &>/dev/null; then\
    CS=$(command -v cs || command -v coursier)\
    try "$CS" install metals\
else\
    echo "[SKIP] coursier (cs) not found."\
    echo "  Install: yay -S coursier  OR  curl -fL https://github.com/coursier/launchers/raw/master/cs-x86_64-pc-linux.gz | gzip -d > ~/.local/bin/cs && chmod +x ~/.local/bin/cs"\
    FAILED+=("metals (coursier not found)")\
fi\
\
# Ōā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤Ć\
# D ŌĆā┤ serve-d\
# Ōā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤Ć\
echo -e "\n=== serve-d (D) ==="\
try yay -S --needed --noconfirm serve-d   # AUR\
\
# Ōā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤Ć\
# PHP ŌĆā┤ phpactor\
# Ōā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤Ć\
echo -e "\n=== phpactor (PHP) ==="\
# Requires PHP + composer\
if command -v composer &>/dev/null; then\
    try composer global require phpactor/phpactor\
    try ln -sf "$HOME/.config/composer/vendor/bin/phpactor" "$HOME/.local/bin/phpactor"\
else\
    echo "[SKIP] composer not found. Install: sudo pacman -S composer"\
    FAILED+=("phpactor (composer not found)")\
fi\
\
# Ōā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤Ć\
# OCaml ŌĆā┤ ocamllsp via opam\
# Ōā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤Ć\
echo -e "\n=== ocaml-lsp-server (OCaml) ==="\
if command -v opam &>/dev/null; then\
    try opam install ocaml-lsp-server\
else\
    echo "[SKIP] opam not found. Install: sudo pacman -S opam  then: opam init"\
    FAILED+=("ocaml-lsp-server (opam not found)")\
fi\
\
# Ōā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤Ć\
# Julia ŌĆā┤ LanguageServer.jl\
# Ōā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤Ć\
echo -e "\n=== LanguageServer.jl (Julia) ==="\
if command -v julia &>/dev/null; then\
    try julia -e 'using Pkg; Pkg.add("LanguageServer")'\
else\
    echo "[SKIP] julia not found. Install: yay -S julia"\
    FAILED+=("LanguageServer.jl (julia not found)")\
fi\
\
# Ōā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤Ć\
# Racket ŌĆā┤ racket-langserver\
# Ōā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤Ć\
echo -e "\n=== racket-langserver ==="\
if command -v raco &>/dev/null; then\
    try raco pkg install --auto racket-langserver\
else\
    echo "[SKIP] raco not found. Install: yay -S racket"\
    FAILED+=("racket-langserver (racket not found)")\
fi\
\
# Ōā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤Ć\
# R ŌĆā┤ languageserver\
# Ōā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤Ć\
echo -e "\n=== languageserver (R) ==="\
if command -v Rscript &>/dev/null; then\
    try Rscript -e 'install.packages("languageserver", repos="https://cloud.r-project.org")'\
else\
    echo "[SKIP] R not found. Install: sudo pacman -S r"\
    FAILED+=("languageserver (R not found)")\
fi\
\
# Ōā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤Ć\
# Nim ŌĆā┤ nimlsp\
# Ōā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤Ć\
echo -e "\n=== nimlsp (Nim) ==="\
if command -v nimble &>/dev/null; then\
    try nimble install nimlsp\
else\
    echo "[SKIP] nimble not found. Install: yay -S nim"\
    FAILED+=("nimlsp (nimble not found)")\
fi\
\
# Ōā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤Ć\
# PureScript runtime (purs)\
# Ōā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤Ć\
echo -e "\n=== PureScript compiler ==="\
try yay -S --needed --noconfirm purescript   # AUR (needed by purescript-language-server)\
\
# Ōā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤Ć\
# Summary\
# Ōā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤ĆŌā┤Ć\
echo -e "\n==============================="\
if [[ ${#FAILED[@]} -eq 0 ]]; then\
    echo "All LSP servers installed successfully."\
else\
    echo "The following steps failed or were skipped:"\
    for f in "${FAILED[@]}"; do\
        echo "  - $f"\
    done\
fi\
echo "==============================="
/home/endchill/Nextcloud/scripts/install-lsp-servers.bash
try ls
hyprshot --help
grimblast check
grimblast usage
/home/linuxbrew/.linuxbrew/bin/brew shellenv zsh
nano /home/linuxbrew/.linuxbrew/bin/brew
ls /home
echo $TERMINFO
echo $TERM
ls 2>/dev/null
ls 1>/dev/null
rm -
git
ls 3>/dev/null
ls 3</dev/null
ls 1</dev/null
jq tmp.json
jq '.' tmp.json
yay -Rns hyprshot
grimblast --help
./grimblast.sh region
./grimblast.sh all
./grimblast.sh screen
./grimblast.sh output
./grimblast.sh area
pacman -Qs hyprpol
sudo pacman -Rns hyprpolkitagent
pacman -Qs hyprqt
ayy -Rns grimblast-git
yay -Rns grimblast-git
yay -S grimblast
hyprpicker -aln
pacman -Qs uwsm libnewt
pacman -Q uwsm libnewt
sudo pacman -Rns uwsm
sudo /home/endchill/Nextcloud/scripts/install-lsp-servers.bash
hyprlauncherd
systemctl status hyprlauncher
systemctl status hyprlauncherd
systemctl --user status hyprlauncherd
systemctl --user status hyprlauncher
sudo nano /etc/systemd/user/hyprlauncherd.service
systemctl --user enable --now hyprlauncher.service
sudo rm /etc/systemd/user/hyprlauncherd.service
nano ~/.config/systemd/user/hyprlauncher.service
