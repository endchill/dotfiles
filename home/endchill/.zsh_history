get_latest_release() {\
 local repo="$1"\
 local filename="$2"\
 local extension="$3"\
 curl -fsSL "https://api.github.com/repos/$repo/releases/latest" | jq -r --arg name "$filename$extension" '.assets[] | select(.name == $name) | .browser_download_url'\
}
