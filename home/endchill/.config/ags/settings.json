{
    "clock": {
        "timeFormat": "%I:%M %p",
        "dateFormat": "%Y.%m.%d",
        "enableHajri": true
    },
    "network": {
        "ethernetBackend": "systemdNetworkd",
        "enableWifi": true,
        "wifiBackend": "iwd",
        "detailed": true
    },
    "audio": {
        "volumeCurve": 2.5,
        "outputSteps": 2,
        "inputSteps": 2
    },
    "music": {
        "bar": {
            "firstLineLabel": true,
            "secondLineLabel": false,
            "cover": true
        },
        "sidePanel": {
            "firstLineLabel": true,
            "secondLineLabel": true,
            "thirdLineLabel": true,
            "cover": true
        },
        "popup": {
            "firstLineLabel": true,
            "secondLineLabel": true,
            "thirdLineLabel": false,
            "cover": false
        },
        "notifications": true,
        "filesDirectories": ["/home/endchill/Music/"],
        "audioDriver": "auto",
        "maxSpeed": 2,
        "minSpeed": 0.5,
        "speedScale": "multipliers",
        "maxPitch": 12,
        "minPitch": -12,
        "pitchScale": "semitones"
    },
    "screenScallingAware": false,
    "scale": 1,
    "monitors": []
}
